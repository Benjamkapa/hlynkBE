# API
PORT=3000
NODE_ENV=development

# Database (PlanetScale / MySQL)
DATABASE_URL="mysql://user:password@host/hlynk?ssl={"rejectUnauthorized":true}"

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_minimum_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_refresh_secret_also_minimum_32_chars
JWT_REFRESH_EXPIRES_IN=30d

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# Qorami SMS
QORAMI_API_KEY=your_qorami_api_key
QORAMI_SENDER_ID=HudumaLynk
QORAMI_BASE_URL=https://api.qorami.com

# Resend (Email)
RESEND_API_KEY=re_your_key_here
RESEND_FROM=noreply@hudumalynk.com

# Cloudflare R2 (Storage)
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=hudumalynk-uploads
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# App
FRONTEND_URL=http://localhost:5173
OTP_EXPIRES_MINUTES=10
